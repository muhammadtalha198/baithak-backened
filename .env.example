# Baithak API — copy to .env and fill real values
# NEVER commit .env to Git!

DATABASE_URL=postgresql+asyncpg://baithak:baithakpass@localhost:5433/baithakdb
REDIS_URL=redis://:devredis@localhost:6379/0

JWT_SECRET=change-me-to-32-plus-random-bytes-in-production
JWT_EXPIRE_MINUTES=15

FRONTEND_URL=http://localhost:5173
OTP_EXPIRE_SECONDS=300
OTP_DEV_MODE=true

FEATURE_LOGIN_ENABLED=true
EARLY_BIRD_LIMIT=50
EARLY_BIRD_DISCOUNT_PERCENT=25

RATE_LIMIT_REGISTER_PER_IP=5
RATE_LIMIT_OTP_PER_IDENTIFIER=3

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@baithak.pk

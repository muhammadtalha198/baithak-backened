# Baithak Backend — Vercel import template (placeholders only)
# 1. Copy:  cp .env.vercel.example .env.vercel
# 2. Fill in real values in .env.vercel
# 3. Vercel → Environment Variables → Import .env → select .env.vercel
# NEVER commit .env.vercel to GitHub!

DATABASE_URL=postgresql+asyncpg://neondb_owner:YOUR_NEON_PASSWORD@ep-your-project.us-east-1.aws.neon.tech/neondb?ssl=require

JWT_SECRET=paste-random-secret-from-openssl-rand-hex-32

FRONTEND_URL=https://baithak-frontened.vercel.app

FEATURE_LOGIN_ENABLED=true

REDIS_URL=

JWT_EXPIRE_MINUTES=60
EARLY_BIRD_LIMIT=50
EARLY_BIRD_DISCOUNT_PERCENT=25
RATE_LIMIT_REGISTER_PER_IP=10
OTP_DEV_MODE=false
